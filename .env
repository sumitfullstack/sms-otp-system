NODE_ENV=development
PORT=3000

# Local MongoDB
MONGODB_URI=mongodb://localhost:27017/sms_otp_dev

# OR MongoDB Atlas (paste your connection string)
# MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/sms_otp_dev

# Generate a strong secret (at least 32 chars)
JWT_SECRET=my-super-secret-key-change-this-please-32chars

# Twilio — OPTIONAL. Leave blank to use mock mode (OTP prints to terminal)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=